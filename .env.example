# Copy to .env and adjust. Docker Compose loads .env for variable substitution in docker-compose.yml.

# UDP (Raspberry Shake → this service)
SHAKE_UDP_BIND_HOST=0.0.0.0
SHAKE_UDP_PORT=8888
SHAKE_UDP_RECV_BUFSIZE=2048

# MQTT broker (set host to your broker; use service name if broker is in same compose stack)
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883
# Base topic: bridge publishes JSON to <base>/json
MQTT_TOPIC=Shake
# Subscribed topic for known anthropogenic events from Home Assistant
# SHAKE_KNOWN_ANTHRO_TOPIC=Shake/known_anthropogenic_event
MQTT_CLIENT_ID=shake-bridge

# Optional authentication
# MQTT_USERNAME=
# MQTT_PASSWORD=

# TLS to broker (set true if broker uses TLS)
MQTT_TLS=false

LOG_LEVEL=INFO

# When true, /json payload is an object with channel, time, n_samples, samples, packet_peak, packet_rms
SHAKE_JSON_STRUCTURED=false

# STA/LTA-style motion detection → publishes JSON to <base>/event (trigger | reset)
SHAKE_DETECT_EVENTS=false
SHAKE_DETECT_STA_SEC=1
SHAKE_DETECT_LTA_SEC=30
SHAKE_DETECT_RATIO_ON=4
SHAKE_DETECT_RATIO_OFF=2
SHAKE_DETECT_COOLDOWN_SEC=5
# No triggers for this many seconds after the process starts (DC / STA-LTA warm-up)
SHAKE_DETECT_STARTUP_GRACE_SEC=5
# Used until sample rate is inferred from packet spacing
SHAKE_DETECT_DEFAULT_FS_HZ=100
# Comma-separated channel codes, e.g. EHZ — empty = all channels
# SHAKE_DETECT_CHANNELS=EHZ

# After a trigger, optional USGS FDSN correlation → <base>/match (requires lat/lon)
SHAKE_CATALOG_ENABLE=false
# SHAKE_CATALOG_LATITUDE=37.7749
# SHAKE_CATALOG_LONGITUDE=-122.4194
SHAKE_CATALOG_MAX_RADIUS_KM=500
SHAKE_CATALOG_TIME_BEFORE_SEC=120
SHAKE_CATALOG_TIME_AFTER_SEC=60
# Seconds after each trigger to run a USGS query (comma-separated; default 60,120,180)
# SHAKE_CATALOG_QUERY_OFFSETS_SEC=60,120,180
# Match using IRIS/EQScope traveltime (origin + first arrival) vs trigger; false = origin time only
# SHAKE_CATALOG_USE_TRAVELTIME=true
# SHAKE_CATALOG_TRAVELTIME_MODEL=iasp91
# SHAKE_CATALOG_TRAVELTIME_TIMEOUT_SEC=6
# SHAKE_CATALOG_TRAVELTIME_MAX_WORKERS=6
# Drop candidates that are too weak for their distance (M2@50mi / M4@300mi log–log curve); keep if mag missing
# SHAKE_CATALOG_SENSITIVITY_FILTER_ENABLE=true
# Shift sensitivity curve on the M axis (e.g. -1 → M1@50mi / M3@300mi instead of M2/M4)
# SHAKE_CATALOG_SENSITIVITY_MAGNITUDE_OFFSET=0

# Rolling match history on {MQTT_TOPIC}/match/history_json (retained JSON; only when catalog is enabled)
# SHAKE_MATCH_HISTORY_ENABLE=true
# SHAKE_MATCH_HISTORY_WINDOW_HOURS=168
# SHAKE_MATCH_HISTORY_MAX_ENTRIES=200

# Optional ShakeNet/QuakeLink time-window URL attached to each history row
# SHAKE_SHAKENET_WINDOW_BASE_URL=https://quakelink.raspberryshake.org/events/query
# SHAKE_SHAKENET_WINDOW_BEFORE_SEC=60
# SHAKE_SHAKENET_WINDOW_AFTER_SEC=180
